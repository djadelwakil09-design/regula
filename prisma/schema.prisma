generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INACTIVE
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  SKIPPED
}

enum ComplianceStatus {
  TODO
  IN_PROGRESS
  COMPLIANT
  NON_COMPLIANT
}

enum NotificationType {
  NEW_REGULATION
  DEADLINE_APPROACHING
  HIGH_RISK
  TASK_DUE
  SYSTEM
}

enum DocumentStatus {
  PENDING
  ANALYZING
  ANALYZED
  ERROR
}

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  firstName     String?
  lastName      String?
  avatarUrl     String?
  role          UserRole @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company?
  notifications Notification[]
  auditLogs     AuditLog[]
  documents     Document[]
  subscription  Subscription?
  tasks         Task[]

  @@index([clerkId])
  @@index([email])
}

model Company {
  id               String  @id @default(cuid())
  userId           String  @unique
  name             String
  siret            String?
  sector           String
  employeeCount    String
  country          String  @default("France")
  region           String?
  companyType      String
  website          String?
  onboardingDone   Boolean @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  complianceScores ComplianceScore[]
  regulations      CompanyRegulation[]

  @@index([userId])
  @@index([sector])
}

model RegulationSource {
  id          String   @id @default(cuid())
  name        String
  url         String
  type        String
  country     String   @default("France")
  isActive    Boolean  @default(true)
  lastFetched DateTime?
  createdAt   DateTime @default(now())

  regulations Regulation[]
}

model Regulation {
  id              String      @id @default(cuid())
  title           String
  slug            String      @unique
  summary         String      @db.Text
  fullText        String?     @db.Text
  aiSummary       String?     @db.Text
  aiImpact        String?     @db.Text
  aiActions       Json?
  aiChecklist     Json?
  aiRisks         String?     @db.Text
  impactLevel     ImpactLevel @default(MEDIUM)
  sectors         String[]
  companySizes    String[]
  countries       String[]
  tags            String[]
  publishedAt     DateTime
  effectiveDate   DateTime?
  deadlineDate    DateTime?
  sourceUrl       String?
  isActive        Boolean     @default(true)
  isAnalyzed      Boolean     @default(false)
  sourceId        String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  source          RegulationSource?  @relation(fields: [sourceId], references: [id])
  companies       CompanyRegulation[]
  tasks           Task[]
  notifications   Notification[]

  @@index([slug])
  @@index([impactLevel])
  @@index([effectiveDate])
  @@index([sectors])
}

model CompanyRegulation {
  id           String           @id @default(cuid())
  companyId    String
  regulationId String
  status       ComplianceStatus @default(TODO)
  notes        String?          @db.Text
  assignedTo   String?
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  regulation   Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)

  @@unique([companyId, regulationId])
  @@index([companyId])
  @@index([regulationId])
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?    @db.Text
  status       TaskStatus @default(TODO)
  priority     Int        @default(1)
  dueDate      DateTime?
  completedAt  DateTime?
  userId       String
  regulationId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  regulation   Regulation? @relation(fields: [regulationId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([dueDate])
}

model ComplianceScore {
  id          String   @id @default(cuid())
  companyId   String
  score       Int
  breakdown   Json?
  period      String
  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([period])
}

model Notification {
  id           String           @id @default(cuid())
  userId       String
  regulationId String?
  type         NotificationType
  title        String
  message      String           @db.Text
  isRead       Boolean          @default(false)
  isEmailSent  Boolean          @default(false)
  metadata     Json?
  createdAt    DateTime         @default(now())

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  regulation   Regulation? @relation(fields: [regulationId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model Document {
  id          String         @id @default(cuid())
  userId      String
  name        String
  originalName String
  fileUrl     String
  fileSize    Int
  mimeType    String
  status      DocumentStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis    DocumentAnalysis?

  @@index([userId])
}

model DocumentAnalysis {
  id              String   @id @default(cuid())
  documentId      String   @unique
  summary         String?  @db.Text
  missingElements Json?
  improvements    Json?
  complianceIssues Json?
  score           Int?
  analyzedAt      DateTime @default(now())

  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String
  resourceId String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
